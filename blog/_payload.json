328},"  },\n",[145,934,935],{"class":314,"line":751},[145,936,754],{"class":328},[245,938,940],{"id":939},"typed-event-handler-requests","Typed Event Handler Requests",[125,942,943],{},"H3 now supports defining event types using new generic type support.",[125,945,946,947,950,951,181,954,294],{},"When you define types, request utilities will be aware of the event input types. This enhancenment also allows us to enhance type safety for ",[237,948,949],{},"$fetch"," handlers in upstream frameworks like ",[170,952,180],{"href":177,"rel":953},[179],[170,955,186],{"href":184,"rel":956},[179],[305,958,960],{"className":307,"code":959,"language":309,"meta":129,"style":129},"export default eventHandler\u003C{ body: { name: string }; query: { id: string } }>(\n  async (event) => {\n    const query = getQuery(event); // Query is typed as { id: string }\n    const body = await readBody(event); // Body is typed as { name: string }\n  },\n);\n",[237,961,962,1009,1023,1042,1062,1066],{"__ignoreMap":129},[145,963,964,966,968,970,973,976,979,982,984,986,989,992,995,997,999,1002,1004,1006],{"class":314,"line":315},[145,965,547],{"class":324},[145,967,550],{"class":324},[145,969,867],{"class":362},[145,971,972],{"class":328},"\u003C{ ",[145,974,975],{"class":404},"body",[145,977,978],{"class":324},":",[145,980,981],{"class":328}," { ",[145,983,919],{"class":404},[145,985,978],{"class":324},[145,987,988],{"class":355}," string",[145,990,991],{"class":328}," }; ",[145,993,994],{"class":404},"query",[145,996,978],{"class":324},[145,998,981],{"class":328},[145,1000,1001],{"class":404},"id",[145,1003,978],{"class":324},[145,1005,988],{"class":355},[145,1007,1008],{"class":328}," } }>(\n",[145,1010,1011,1013,1015,1017,1019,1021],{"class":314,"line":130},[145,1012,884],{"class":324},[145,1014,642],{"class":328},[145,1016,405],{"class":404},[145,1018,408],{"class":328},[145,1020,411],{"class":324},[145,1022,564],{"class":328},[145,1024,1025,1028,1031,1033,1036,1039],{"class":314,"line":342},