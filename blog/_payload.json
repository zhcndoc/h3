":114,"__hash__":1472},"content/99.blog/1.v1.8.md",{"type":122,"value":163,"toc":1455},[164,188,207,221,224,244,249,269,295,304,448,455,468,471,502,506,527,538,755,765,769,772,937,941,944,957,1070,1074,1090,1285,1289,1292,1335,1339,1348,1355,1418,1425,1432,1439,1443,1451],[165,166,167],"blockquote",{},[125,168,169,174,175,181,182,187],{},[170,171,173],"a",{"href":172},"/packages/h3","H3"," is a versatile H(TTP) framework written in TypeScript that powers both ",[170,176,180],{"href":177,"rel":178},"https://nitro.unjs.io/",[179],"nofollow","Nitro"," and ",[170,183,186],{"href":184,"rel":185},"https://nuxt.com/",[179],"Nuxt"," today.",[125,189,190,195,196,200,201,206],{},[170,191,194],{"href":192,"rel":193},"https://github.com/unjs/h3/tree/cbc8909b2003d6d5df694ab7a36aa067cc990c74",[179],"Almost two years ago",", we made H3 with the ambition to become the smallest HTTP framework for ",[170,197,199],{"href":184,"rel":198},[179],"Nuxt 3",", ensuring compatibility with ",[170,202,205],{"href":203,"rel":204},"https://nodejs.org/en",[179],"Node.js"," and providing an elegant developer experience. It also aimed to have a futuristic design, being adaptable to Edge and Web Worker runtimes, a concept that was relatively new at the time.",[125,208,209,210,215,216,220],{},"During the same period, we also developed ",[170,211,214],{"href":212,"rel":213},"https://github.com/unjs/unenv/tree/main",[179],"unjs/unenv",", a thin layer that enabled the utilization of Node.js libraries and HTTP middleware for Edge-compatible runtimes without the need for Node.js. This innovation played a pivotal role in enabling us to harness the power of the NPM and Node.js ecosystem without starting everything from scratch for web compatibility. The synergistic combination of H3 and unenv culminated in making ",[170,217,180],{"href":218,"rel":219},"https://nitro.unjs.io",[179]," one of the pioneering web frameworks fully compatible with Edge runtimes.",[125,222,223],{},"This latest release takes H3 even closer to offering native Web API compatibility right out of the box.",[165,225,226],{},[125,227,228,229,181,232,235,236,181,240,243],{},"🚀 This release is immediately available for all ecosystem packages including ",[170,230,180],{"href":177,"rel":231},[179],[170,233,199],{"href":184,"rel":234},[179],". Please remember to refresh your ",[237,238,239],"code",{},"lockfile",[237,241,242],{},"node_modules"," to receive the updates.",[245,246,248],"h2",{"id":247},"web-and-plain-adapters","Web and Plain Adapters",[125,250,251,252,257,258,263,264,268],{},"We have introduced a new built-in adapter with a ",[170,253,256],{"href":254,"rel":255},"https://developer.mozilla.org/en-US/docs/Web/API/Fetch_API",[179],"fetch","-compatible signature, with ",[170,259,262],{"href":260,"rel":261},"https://developer.mozilla.org/en-US/docs/Web/API/Request",[179],"Request"," as input and ",[170,265,54],{"href":266,"rel":267},"https://developer.mozilla.org/en-US/docs/Web/API/Response",[179]," as the return value.",[125,270,271,272,277,278,277,283,288,289,294],{},"What this signifies is that you can now seamlessly deploy your H3 applications on runtimes such as ",[170,273,276],{"href":274,"rel":275},"https://workers.cloudflare.com/",[179],"Cloudflare Workers",", ",[170,279,282],{"href":280,"rel":281},"https://deno.com/deploy",[179],"Deno Deploy",[170,284,287],{"href":285,"rel":286},"https://bun.sh/",[179],"Bun",", and ",[170,290,293],{"href":291,"rel":292},"https://lagon.app/",[179],"Lagon",".",[125,296,297,298,303],{},"For practical examples and a demo, check out the ",[170,299,302],{"href":300,"rel":301},"https://github.com/pi0/h3-on-edge",[179],"h3-on-edge"," repository.",[305,306,310],"pre",{"className":307,"code":308,"language":309,"meta":129,"style":129},"language-ts shiki shiki-themes github-light github-dark github-dark","// import { createApp, eventHandler, toWebHandler } from 'h3'\nimport { createApp, eventHandler, toWebHandler } from \"https://esm.sh/h3@1.8.0\";\n\nconst app = createApp();\n\napp.use(\n  \"/\",\n  eventHandler((event) => \"H3 works on edge!\"),\n);\n\nconst webHandler = toWebHandler(app); // (Request) => Promise\u003CResponse>\n","ts",[237,311,312,320,340,347,367,372,384,393,418,424,429],{"__ignoreMap":129},[145,313,316],{"class":314,"line":315},"line",1,[145,317,319],{"class":318},"sCsY4","// import { createApp, eventHandler, toWebHandler } from 'h3'\n",[145,321,322,326,330,333,337],{"class":314,"line":130},[145,323,325],{"class":324},"so5gQ","import",[145,327,329],{"class":328},"slsVL"," { createApp, eventHandler, toWebHandler } ",[145,331,332],{"class":324},"from",[145,334,336],{"class":335},"sfrk1"," \"https://esm.sh/h3@1.8.0\"",[145,338,339],{"class":328},";\n",[145,341,343],{"class":314,"line":342},3,[145,344,346],{"emptyLinePlaceholder":345},true,"\n",[145,348,350,353,357,360,364],{"class":314,"line":349},4,[145,351,352],{"class":324},"const",[145,354,356],{"class":355},"suiK_"," app",[145,358,359],{"class":324}," =",[145,361,363],{"class":362},"shcOC"," createApp",[145,365,366],{"class":328},"();\n",[145,368,370],{"class":314,"line":369},5,[145,371,346],{"emptyLinePlaceholder":345},[145,373,375,378,381],{"class":314,"line":374},6,[145,376,377],{"class":328},"app.",[145,379,380],{"class":362},"use",[145,382,383],{"class":328},"(\n",[145,385,387,390],{"class":314,"line":386},7,[145,388,389],{"class":335},"  \"/\"",[145,391,392],{"class":328},",\n",[145,394,396,399,402,406,409,412,415],{"class":314,"line":395},8,[145,397,398],{"class":362},"  eventHandler",[145,400,401],{"class":328},"((",[145,403,405],{"class":404},"sQHwn","event",[145,407,408],{"class":328},") ",[145,410,411],{"class":324},"=>",[145,413,414],{"class":335}," \"H3 works on edge!\"",[145,416,417],{"class":328},"),\n",[145,419,421],{"class":314,"line":420},9,[145,422,423],{"class":328},");\n",[145,425,427],{"class":314,"line":426},10,[145,428,346],{"emptyLinePlaceholder":345},[145,430,432,434,437,439,442,445],{"class":314,"line":431},11,[145,433,352],{"class":324},[145,435,436],{"class":355}," webHandler",[145,438,359],{"class":324},[145,440,441],{"class":362}," toWebHandler",[145,443,444],{"class":328},"(app); ",[145,446,447],{"class":318},"// (Request) => Promise\u003CResponse>\n",[125,449,450,451,454],{},"In addition to web handlers, we've also introduced a new plain adapter format using the ",[237,452,453],{},"toPlainHandler(app)"," syntax. This facilitates the seamless integration of H3 with any serverless platform using plain input and response objects.",[125,456,457,458,462,463,294],{},"All of these became possible due to the implementation of new streaming capabilities and ",[170,459,214],{"href":460,"rel":461},"https://unenv.unjs.io",[179],", which provides a lightweight Node.js compatibility layer. Previously, this level of integration was only possible through ",[170,464,467],{"href":465,"rel":466},"https://nitro.unjs.io/deploy",[179],"Nitro presets",[125,469,470],{},"Furthermore, we've introduced a set of new web helpers:",[472,473,474,484,490,496],"ul",{},[475,476,477,480,481,294],"li",{},[237,478,479],{},"toWebRequest(event)",": Convert a H3 event object into a web ",[170,482,262],{"href":260,"rel":483},[179],[475,485,486,489],{},[237,487,488],{},"getRequestWebStream(event)",": Retrieve a readable stream from the current H3 event request.",[475,491,492,495],{},[237,493,494],{},"fromPlainHandler(plainHandler)",": Convert a plain object handler into an H3-compatible event handler.",[475,497,498,501],{},[237,499,500],{},"fromWebHandler(webHandler)",": Convert a Web Request/Response handler into an H3-compatible event handler.",[245,503,505],{"id":504},"web-streams-support","Web Streams Support",[125,507,508,509,514,515,520,521,526],{},"H3 now supports native ",[170,510,513],{"href":511,"rel":512},"https://developer.mozilla.org/en-US/docs/Web/API/ReadableStream",[179],"Readable Stream"," response support. This inherently brings compatibility with libraries like ",[170,516,519],{"href":517,"rel":518},"https://github.com/vercel/ai",[179],"Vercel/AI",", which rely on streaming responses (",[170,522,525],{"href":523,"rel":524},"https://github.com/Hebilicious/nuxt-openai-vercel-edge-demo",[179],"demo",").",[125,528,529,530,533,534,537],{},"Leveraging this functionality is straightforward—simply return a ",[170,531,513],{"href":511,"rel":532},[179]," or ",[170,535,54],{"href":266,"rel":536},[179]," object from your event handlers.",[305,539,541],{"className":307,"code":540,"language":309,"meta":129,"style":129},"export default defineEventHandler((event) => {\n  setResponseHeader(event, \"Content-Type\", \"text/html\");\n  const encoder = new TextEncoder();\n  const stream = new ReadableStream({\n    async start(controller) {\n      for (const token of \"Streaming is so cool with H3!\".split(\" \")) {\n        controller.enqueue(encoder.encode(token));\n        await new Promise((resolve) => {\n          setTimeout(resolve, 300);\n        });\n      }\n    },\n  });\n  return stream;\n});\n",[237,542,543,565,583,601,618,635,667,684,705,718,723,728,734,740,749],{"__ignoreMap":129},[145,544,545,548,551,554,556,558,560,562],{"class":314,"line":315},[145,546,547],{"class":324},"export",[145,549,550],{"class":324}," default",[145,552,553],{"class":362}," defineEventHandler",[145,555,401],{"class":328},[145,557,405],{"class":404},[145,559,408],{"class":328},[145,561,411],{"class":324},[145,563,564],{"class":328}," {\n",[145,566,567,570,573,576,578,581],{"class":314,"line":130},[145,568,569],{"class":362},"  setResponseHeader",[145,571,572],{"class":328},"(event, ",[145,574,575],{"class":335},"\"Content-Type\"",[145,577,277],{"class":328},[145,579,580],{"class":335},"\"text/html\"",[145,582,423],{"class":328},[145,584,585,588,591,593,596,599],{"class":314,"line":342},[145,586,587],{"class":324},"  const",[145,589,590],{"class":355}," encoder",[145,592,359],{"class":324},[145,594,595],{"class":324}," new",[145,597,598],{"class":362}," TextEncoder",[145,600,366],{"class":328},[145,